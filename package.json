{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "db:init": "bun -e \"import { initSchema } from './src/db/dao'; initSchema(); console.log('✓ schema initialized')\"",
    "db:migrate": "bun src/db/migrate.ts",
    "db:reset": "rm -f data/shop.db && bun run db:init",
    "db:seed": "bun run db:init && bun src/db/seed.ts",
    "test": "bun test",
    "test:dao": "bun test src/db/dao/dao.integration.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  }
}
